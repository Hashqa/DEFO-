    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "stripe": "^16.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.15",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.18.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
