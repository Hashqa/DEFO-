# Base de données (multi-tenant, isolation par accountId)
DATABASE_URL="postgresql://user:password@localhost:5432/defa"

# Serveur
PORT=3001

# Peppol (Access Point certifié — ex. Storecove, Recommand)
PEPPOL_PROVIDER=storecove
PEPPOL_API_KEY=

# Rapprochement bancaire PSD2 (ex. Ponto)
PONTO_CLIENT_ID=
PONTO_CLIENT_SECRET=

# Abonnements
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
