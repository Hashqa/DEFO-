# Base de données (multi-tenant, isolation par accountId)
DATABASE_URL="postgresql://user:password@localhost:5432/defa"

# Serveur
PORT=3001

# Auth (JWT)
JWT_SECRET=change-me-in-production

# CORS : origine autorisée du dashboard web
WEB_APP_ORIGIN=http://localhost:3000

# Peppol (Access Point certifié : Recommand — https://app.recommand.eu/api-keys)
RECOMMAND_BASE_URL=https://app.recommand.eu/api/v1
RECOMMAND_API_KEY=
RECOMMAND_API_SECRET=

# Rapprochement bancaire PSD2 (ex. Ponto)
PONTO_CLIENT_ID=
PONTO_CLIENT_SECRET=

# Abonnements (Stripe — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
PUBLIC_APP_URL=http://localhost:3000

# Relances automatiques (section 3.7)
REMINDER_AFTER_DAYS=7
REMINDER_INTERVAL_DAYS=7
